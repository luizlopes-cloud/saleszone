# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# scripts runtime data
scripts/**/logs/*.log
scripts/**/snapshots/*.json
scripts/**/outputs/

# supabase CLI state
supabase/.temp/

# Supabase staging/dump (contain connection strings and credentials)
.supabase_prod_uri.txt
.supabase_staging_uri.txt
supabase_staging_ref.txt
supabase_dump_prod.sql
supabase_dump_prod.backup
supabase_dump_data.sql

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# debug scripts
capture_*.mjs
*.debug.mjs

# Supabase staging
supabase_staging_ref.txt
supabase_staging_api_key.txt
supabase_staging_password.txt
.supabase_staging_keys.env
.supabase_staging_keys.txt
.supabase_staging_password.txt
.supabase_staging_uri.txt
.supabase_prod_uri.txt
supabase_dump_*.sql
supabase_dump_*.backup
supabase_dump_chunks/
